# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real token.

# Figma personal access token
# Generate at: Figma → top-left menu → Help and account → Account settings → Security
# Required scopes: File content (read)
FIGMA_TOKEN=your_token_here

# Figma file key (extracted from the file URL)
# e.g. https://www.figma.com/design/{FILE_KEY}/...
FIGMA_FILE_KEY=necw5Yysi70I8c7wbm3bmv
